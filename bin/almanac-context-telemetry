#!/usr/bin/env python3
from __future__ import annotations

import argparse
from collections import Counter
import json
import os
from pathlib import Path
from typing import Any


DEFAULT_RELATIVE_PATH = Path("state") / "almanac-context-telemetry.jsonl"


def _default_path() -> Path:
    hermes_home = Path(os.environ.get("HERMES_HOME") or (Path.home() / ".hermes")).expanduser()
    return hermes_home / DEFAULT_RELATIVE_PATH


def _iter_records(path: Path) -> tuple[list[dict[str, Any]], int]:
    if not path.is_file():
        return [], 0
    records: list[dict[str, Any]] = []
    invalid = 0
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            payload = json.loads(line)
        except Exception:
            invalid += 1
            continue
        if isinstance(payload, dict):
            records.append(payload)
        else:
            invalid += 1
    return records, invalid


def _counter_to_dict(counter: Counter[str]) -> dict[str, int]:
    return {key: counter[key] for key, _ in counter.most_common()}


def summarize(paths: list[Path]) -> dict[str, Any]:
    records: list[dict[str, Any]] = []
    invalid_lines = 0
    missing_files: list[str] = []
    for path in paths:
        file_records, file_invalid = _iter_records(path)
        if not path.is_file():
            missing_files.append(str(path))
        records.extend(file_records)
        invalid_lines += file_invalid

    injected = [record for record in records if record.get("injected") is True]
    suppressed = [record for record in records if record.get("injected") is False]
    gates: Counter[str] = Counter()
    recipes: Counter[str] = Counter()
    modes: Counter[str] = Counter()
    platforms: Counter[str] = Counter()
    reasons: Counter[str] = Counter()
    context_chars: list[int] = []
    revisions: set[str] = set()
    timestamps: list[str] = []

    for record in records:
        ts = str(record.get("ts") or "").strip()
        if ts:
            timestamps.append(ts)
        revision = str(record.get("managed_revision") or "").strip()
        if revision:
            revisions.add(revision)
        platform = str(record.get("platform") or "unknown").strip() or "unknown"
        platforms[platform] += 1
        reason = str(record.get("reason") or "").strip()
        if reason:
            reasons[reason] += 1
        mode = str(record.get("context_mode") or ("suppressed" if record.get("injected") is False else "unknown")).strip()
        modes[mode] += 1
        chars = record.get("context_chars")
        if isinstance(chars, int):
            context_chars.append(chars)
        raw_gates = record.get("gate")
        if isinstance(raw_gates, list):
            for gate in raw_gates:
                label = str(gate or "").strip()
                if label:
                    gates[label] += 1
        raw_recipes = record.get("recipes")
        if isinstance(raw_recipes, list):
            for recipe in raw_recipes:
                label = str(recipe or "").strip()
                if label:
                    recipes[label] += 1

    return {
        "paths": [str(path) for path in paths],
        "missing_files": missing_files,
        "records": len(records),
        "invalid_lines": invalid_lines,
        "injected": len(injected),
        "suppressed": len(suppressed),
        "context_modes": _counter_to_dict(modes),
        "gates": _counter_to_dict(gates),
        "recipes": _counter_to_dict(recipes),
        "platforms": _counter_to_dict(platforms),
        "reasons": _counter_to_dict(reasons),
        "avg_context_chars": round(sum(context_chars) / len(context_chars), 1) if context_chars else 0,
        "max_context_chars": max(context_chars) if context_chars else 0,
        "managed_revisions": len(revisions),
        "first_ts": min(timestamps) if timestamps else "",
        "last_ts": max(timestamps) if timestamps else "",
    }


def _format_counter(title: str, values: dict[str, int]) -> list[str]:
    if not values:
        return [f"{title}: none"]
    return [f"{title}: " + ", ".join(f"{key}={value}" for key, value in values.items())]


def render_human(summary: dict[str, Any]) -> str:
    lines = [
        "Almanac context telemetry",
        f"sources: {', '.join(summary['paths'])}",
    ]
    if summary["missing_files"]:
        lines.append(f"missing: {', '.join(summary['missing_files'])}")
    lines.extend(
        [
            f"records: {summary['records']} (invalid lines: {summary['invalid_lines']})",
            f"injected: {summary['injected']}; suppressed: {summary['suppressed']}",
            f"context chars: avg={summary['avg_context_chars']} max={summary['max_context_chars']}",
            f"managed revisions seen: {summary['managed_revisions']}",
        ]
    )
    if summary["first_ts"] or summary["last_ts"]:
        lines.append(f"window: {summary['first_ts']} -> {summary['last_ts']}")
    lines.extend(_format_counter("context modes", summary["context_modes"]))
    lines.extend(_format_counter("gates", summary["gates"]))
    lines.extend(_format_counter("recipes", summary["recipes"]))
    lines.extend(_format_counter("platforms", summary["platforms"]))
    lines.extend(_format_counter("suppression reasons", summary["reasons"]))
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Summarize almanac-managed-context JSONL telemetry.")
    parser.add_argument("paths", nargs="*", type=Path, help="Telemetry JSONL path(s). Defaults to $HERMES_HOME/state/almanac-context-telemetry.jsonl.")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
    args = parser.parse_args(argv)

    paths = args.paths or [_default_path()]
    summary = summarize([path.expanduser() for path in paths])
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        print(render_human(summary))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
