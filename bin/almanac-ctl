#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/common.sh"

needs_root=0
domain_arg=""
action_arg=""
for arg in "$@"; do
  if [[ "$arg" == "--json" ]]; then
    continue
  fi
  if [[ -z "$domain_arg" ]]; then
    domain_arg="$arg"
    continue
  fi
  action_arg="$arg"
  break
done

if [[ "$domain_arg" == "user" && "$action_arg" == "prepare" ]]; then
  needs_root=1
elif [[ "$domain_arg" == "agent" && "$action_arg" == "deenroll" ]]; then
  needs_root=1
elif [[ "$domain_arg" == "retrieval" && "$action_arg" == "replay" ]]; then
  needs_root=1
fi

if [[ "$needs_root" != "1" && ${EUID:-$(id -u)} -ne 0 && -n "${CONFIG_FILE:-}" && ! -r "$CONFIG_FILE" ]]; then
  exec sudo env \
    ALMANAC_CONFIG_FILE="$CONFIG_FILE" \
    PYTHONPATH="$BOOTSTRAP_DIR/python${PYTHONPATH:+:$PYTHONPATH}" \
    "$0" "$@"
fi

if [[ "$needs_root" == "1" && ${EUID:-$(id -u)} -ne 0 ]]; then
  exec sudo env \
    ALMANAC_CONFIG_FILE="${ALMANAC_CONFIG_FILE:-$CONFIG_FILE}" \
    PYTHONPATH="$BOOTSTRAP_DIR/python${PYTHONPATH:+:$PYTHONPATH}" \
    "$0" "$@"
fi

export PYTHONPATH="$BOOTSTRAP_DIR/python${PYTHONPATH:+:$PYTHONPATH}"
PYTHON_BIN="$(resolve_runtime_python)"
exec "$PYTHON_BIN" "$BOOTSTRAP_DIR/python/almanac_ctl.py" "$@"
