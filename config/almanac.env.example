ALMANAC_NAME=almanac
ALMANAC_USER=almanac
ALMANAC_HOME=/home/almanac
ALMANAC_REPO_DIR=/home/almanac/almanac
ALMANAC_PRIV_DIR=/home/almanac/almanac/almanac-priv
ALMANAC_PRIV_CONFIG_DIR=/home/almanac/almanac/almanac-priv/config
VAULT_DIR=/home/almanac/almanac/almanac-priv/vault
STATE_DIR=/home/almanac/almanac/almanac-priv/state
NEXTCLOUD_STATE_DIR=/home/almanac/almanac/almanac-priv/state/nextcloud
RUNTIME_DIR=/home/almanac/almanac/almanac-priv/state/runtime
PUBLISHED_DIR=/home/almanac/almanac/almanac-priv/published
ALMANAC_DB_PATH=/home/almanac/almanac/almanac-priv/state/almanac-control.sqlite3
ALMANAC_AGENTS_STATE_DIR=/home/almanac/almanac/almanac-priv/state/agents
ALMANAC_CURATOR_DIR=/home/almanac/almanac/almanac-priv/state/curator
ALMANAC_CURATOR_MANIFEST=/home/almanac/almanac/almanac-priv/state/curator/manifest.json
ALMANAC_CURATOR_HERMES_HOME=/home/almanac/almanac/almanac-priv/state/curator/hermes-home
ALMANAC_ARCHIVED_AGENTS_DIR=/home/almanac/almanac/almanac-priv/state/archived-agents

QMD_INDEX_NAME=almanac
QMD_COLLECTION_NAME=vault
VAULT_QMD_COLLECTION_MASK=**/*.{md,markdown,mdx,txt,text}
PDF_INGEST_COLLECTION_NAME=vault-pdf-ingest
QMD_RUN_EMBED=1
QMD_MCP_PORT=8181
ALMANAC_MCP_HOST=127.0.0.1
ALMANAC_MCP_PORT=8282
ALMANAC_MCP_URL=http://127.0.0.1:8282/mcp
ALMANAC_NOTION_WEBHOOK_HOST=127.0.0.1
ALMANAC_NOTION_WEBHOOK_PORT=8283
ALMANAC_BOOTSTRAP_WINDOW_SECONDS=3600
ALMANAC_BOOTSTRAP_PER_IP_LIMIT=5
ALMANAC_BOOTSTRAP_GLOBAL_PENDING_LIMIT=20
ALMANAC_BOOTSTRAP_PENDING_TTL_SECONDS=900
PDF_INGEST_ENABLED=1
PDF_INGEST_EXTRACTOR=auto
PDF_INGEST_TRIGGER_QMD_REFRESH=1
PDF_INGEST_WATCH_DEBOUNCE_SECONDS=10
PDF_INGEST_DOCLING_FORCE_OCR=0
PDF_VISION_ENDPOINT=
PDF_VISION_MODEL=
PDF_VISION_API_KEY=
PDF_VISION_MAX_PAGES=6
VAULT_WATCH_DEBOUNCE_SECONDS=5
VAULT_WATCH_RUN_EMBED=auto

BACKUP_GIT_BRANCH=main
BACKUP_GIT_REMOTE=git@github.com:your-org/almanac-priv.git
BACKUP_GIT_AUTHOR_NAME="Almanac Backup"
BACKUP_GIT_AUTHOR_EMAIL=almanac@localhost
ALMANAC_UPSTREAM_REPO_URL=https://github.com/example/almanac.git
ALMANAC_UPSTREAM_BRANCH=main
# Optional operator/agent deploy key for the Almanac upstream repo. First
# install can generate this key and print the GitHub deploy-key URL/public key.
# This key is for code pushes back to the repo; enable GitHub "Allow write
# access". The almanac-priv backup and each user's Hermes-home backup use
# separate deploy keys.
ALMANAC_UPSTREAM_DEPLOY_KEY_ENABLED=0
ALMANAC_UPSTREAM_DEPLOY_KEY_USER=
ALMANAC_UPSTREAM_DEPLOY_KEY_PATH=
ALMANAC_UPSTREAM_KNOWN_HOSTS_FILE=

NEXTCLOUD_PORT=18080
NEXTCLOUD_TRUSTED_DOMAIN=almanac.your-tailnet.ts.net
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=generated-at-deploy
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=generated-at-deploy
NEXTCLOUD_VAULT_MOUNT_POINT=/Vault

ENABLE_NEXTCLOUD=1
ENABLE_TAILSCALE_SERVE=0
TAILSCALE_OPERATOR_USER=almanac
OPERATOR_NOTIFY_CHANNEL_PLATFORM=tui-only
OPERATOR_NOTIFY_CHANNEL_ID=
OPERATOR_GENERAL_CHANNEL_PLATFORM=
OPERATOR_GENERAL_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
# Model provider defaults are declared in config/model-providers.yaml. These
# env vars are override hooks for a host that intentionally wants a different
# exact target.
ALMANAC_MODEL_PRESET_CODEX=openai-codex:gpt-5.5
ALMANAC_MODEL_PRESET_OPUS=anthropic:claude-opus-4-7
ALMANAC_MODEL_PRESET_CHUTES=chutes:moonshotai/Kimi-K2.6-TEE
# Hermes upstream pin fallback for early bootstrap. config/pins.json is the
# source of truth once the repo is present.
ALMANAC_HERMES_AGENT_REF=98d75dea5a86aec599b1e081f8bbe9170bd3f964
ALMANAC_HERMES_DOCS_SYNC_ENABLED=1
ALMANAC_HERMES_DOCS_REPO_URL=https://github.com/NousResearch/hermes-agent.git
# Docs pin fallback for early bootstrap. config/pins.json keeps docs aligned
# with the pinned runtime once the repo is present.
ALMANAC_HERMES_DOCS_REF=98d75dea5a86aec599b1e081f8bbe9170bd3f964
ALMANAC_HERMES_DOCS_SOURCE_SUBDIR=website/docs
ALMANAC_HERMES_DOCS_STATE_DIR=/home/almanac/almanac/almanac-priv/state/hermes-docs-src
ALMANAC_HERMES_DOCS_VAULT_DIR=/home/almanac/almanac/almanac-priv/vault/Agents_KB/hermes-agent-docs
ALMANAC_EXTRA_MCP_NAME=external-kb
ALMANAC_EXTRA_MCP_LABEL="External knowledge rail"
ALMANAC_EXTRA_MCP_URL=
ALMANAC_AGENT_DASHBOARD_BACKEND_PORT_BASE=19000
ALMANAC_AGENT_DASHBOARD_PROXY_PORT_BASE=29000
ALMANAC_AGENT_CODE_PORT_BASE=39000
ALMANAC_AGENT_PORT_SLOT_SPAN=5000
ALMANAC_AGENT_CODE_SERVER_IMAGE=docker.io/codercom/code-server:4.116.0
ALMANAC_SSOT_NOTION_ROOT_PAGE_URL=
ALMANAC_SSOT_NOTION_ROOT_PAGE_ID=
ALMANAC_SSOT_NOTION_SPACE_URL=
ALMANAC_SSOT_NOTION_SPACE_ID=
ALMANAC_SSOT_NOTION_SPACE_KIND=
ALMANAC_SSOT_NOTION_API_VERSION=2026-03-11
ALMANAC_SSOT_NOTION_TOKEN=
# Leave blank to follow ENABLE_TAILSCALE_SERVE.
ALMANAC_AGENT_ENABLE_TAILSCALE_SERVE=
ENABLE_PRIVATE_GIT=1
ENABLE_QUARTO=1
SEED_SAMPLE_VAULT=1

QUARTO_PROJECT_DIR=/home/almanac/almanac/almanac-priv/quarto
QUARTO_OUTPUT_DIR=/home/almanac/almanac/almanac-priv/published
