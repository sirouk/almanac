ARCLINK_NAME=arclink
ARCLINK_USER=arclink
ARCLINK_HOME=/home/arclink
ARCLINK_REPO_DIR=/home/arclink/arclink
ARCLINK_PRIV_DIR=/home/arclink/arclink/arclink-priv
ARCLINK_PRIV_CONFIG_DIR=/home/arclink/arclink/arclink-priv/config
VAULT_DIR=/home/arclink/arclink/arclink-priv/vault
STATE_DIR=/home/arclink/arclink/arclink-priv/state
NEXTCLOUD_STATE_DIR=/home/arclink/arclink/arclink-priv/state/nextcloud
RUNTIME_DIR=/home/arclink/arclink/arclink-priv/state/runtime
PUBLISHED_DIR=/home/arclink/arclink/arclink-priv/published
ARCLINK_DB_PATH=/home/arclink/arclink/arclink-priv/state/arclink-control.sqlite3
ARCLINK_AGENTS_STATE_DIR=/home/arclink/arclink/arclink-priv/state/agents
ARCLINK_CURATOR_DIR=/home/arclink/arclink/arclink-priv/state/curator
ARCLINK_CURATOR_MANIFEST=/home/arclink/arclink/arclink-priv/state/curator/manifest.json
ARCLINK_CURATOR_HERMES_HOME=/home/arclink/arclink/arclink-priv/state/curator/hermes-home
ARCLINK_ARCHIVED_AGENTS_DIR=/home/arclink/arclink/arclink-priv/state/archived-agents

QMD_INDEX_NAME=arclink
QMD_COLLECTION_NAME=vault
VAULT_QMD_COLLECTION_MASK=**/*.{md,markdown,mdx,txt,text}
PDF_INGEST_COLLECTION_NAME=vault-pdf-ingest
QMD_RUN_EMBED=1
QMD_EMBED_PROVIDER=local
QMD_EMBED_ENDPOINT=
QMD_EMBED_ENDPOINT_MODEL=
QMD_EMBED_API_KEY=
QMD_EMBED_DIMENSIONS=
QMD_EMBED_TIMEOUT_SECONDS=120
QMD_EMBED_MAX_DOCS_PER_BATCH=8
QMD_EMBED_MAX_BATCH_MB=16
QMD_EMBED_FORCE_ON_NEXT_REFRESH=0
QMD_MCP_PORT=8181
ARCLINK_MCP_HOST=127.0.0.1
ARCLINK_MCP_PORT=8282
ARCLINK_MCP_URL=http://127.0.0.1:8282/mcp
ARCLINK_NOTION_WEBHOOK_HOST=127.0.0.1
ARCLINK_NOTION_WEBHOOK_PORT=8283
ARCLINK_BOOTSTRAP_WINDOW_SECONDS=3600
ARCLINK_BOOTSTRAP_PER_IP_LIMIT=5
ARCLINK_BOOTSTRAP_GLOBAL_PENDING_LIMIT=20
ARCLINK_BOOTSTRAP_PENDING_TTL_SECONDS=900
PDF_INGEST_ENABLED=1
PDF_INGEST_EXTRACTOR=auto
PDF_INGEST_TRIGGER_QMD_REFRESH=1
PDF_INGEST_WATCH_DEBOUNCE_SECONDS=10
PDF_INGEST_DOCLING_FORCE_OCR=0
PDF_VISION_ENDPOINT=
PDF_VISION_MODEL=
PDF_VISION_API_KEY=
ARCLINK_SESSION_HASH_PEPPER=
ARCLINK_SESSION_HASH_PEPPER_REQUIRED=0
PDF_VISION_MAX_PAGES=6
ARCLINK_MEMORY_SYNTH_ENABLED=auto
ARCLINK_MEMORY_SYNTH_ENDPOINT=
ARCLINK_MEMORY_SYNTH_MODEL=
ARCLINK_MEMORY_SYNTH_API_KEY=
ARCLINK_MEMORY_SYNTH_MAX_SOURCES_PER_RUN=12
ARCLINK_MEMORY_SYNTH_MAX_SOURCE_CHARS=4500
ARCLINK_MEMORY_SYNTH_MAX_OUTPUT_TOKENS=450
ARCLINK_MEMORY_SYNTH_TIMEOUT_SECONDS=60
ARCLINK_MEMORY_SYNTH_FAILURE_RETRY_SECONDS=3600
ARCLINK_MEMORY_SYNTH_CARDS_IN_CONTEXT=8
VAULT_WATCH_DEBOUNCE_SECONDS=5
VAULT_WATCH_RUN_EMBED=auto

BACKUP_GIT_BRANCH=main
BACKUP_GIT_REMOTE=git@github.com:your-org/arclink-priv.git
BACKUP_GIT_AUTHOR_NAME="ArcLink Backup"
BACKUP_GIT_AUTHOR_EMAIL=arclink@localhost
ARCLINK_UPSTREAM_REPO_URL=https://github.com/example/arclink.git
ARCLINK_UPSTREAM_BRANCH=arclink
# Optional operator/agent deploy key for the ArcLink upstream repo. First
# install can generate this key and print the GitHub deploy-key URL/public key.
# This key is for code pushes back to the repo; enable GitHub "Allow write
# access". The arclink-priv backup and each user's Hermes-home backup use
# separate deploy keys.
ARCLINK_UPSTREAM_DEPLOY_KEY_ENABLED=0
ARCLINK_UPSTREAM_DEPLOY_KEY_USER=
ARCLINK_UPSTREAM_DEPLOY_KEY_PATH=
ARCLINK_UPSTREAM_KNOWN_HOSTS_FILE=

NEXTCLOUD_PORT=18080
NEXTCLOUD_TRUSTED_DOMAIN=arclink.your-tailnet.ts.net
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=generated-at-deploy
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=generated-at-deploy
NEXTCLOUD_VAULT_MOUNT_POINT=/Vault

ENABLE_NEXTCLOUD=1
ENABLE_TAILSCALE_SERVE=0
TAILSCALE_OPERATOR_USER=arclink
OPERATOR_NOTIFY_CHANNEL_PLATFORM=tui-only
OPERATOR_NOTIFY_CHANNEL_ID=
OPERATOR_GENERAL_CHANNEL_PLATFORM=
OPERATOR_GENERAL_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# ArcLink SaaS foundation defaults. ARCLINK_* values take precedence over
# legacy aliases when non-empty; blank ARCLINK_* values fall back to legacy
# settings so partially rendered env files do not erase working deploy config.
ARCLINK_PRODUCT_NAME=ArcLink
ARCLINK_BASE_DOMAIN=localhost
ARCLINK_PRIMARY_PROVIDER=chutes
ARCLINK_CHUTES_BASE_URL=https://llm.chutes.ai/v1
ARCLINK_CHUTES_DEFAULT_MODEL=moonshotai/Kimi-K2.6-TEE
ARCLINK_MODEL_REASONING_DEFAULT=medium
# Model provider defaults are declared in config/model-providers.yaml. These
# env vars are override hooks for a host that intentionally wants a different
# exact target.
ARCLINK_MODEL_PRESET_CODEX=openai-codex:gpt-5.5
ARCLINK_MODEL_PRESET_OPUS=anthropic:claude-opus-4-7
ARCLINK_MODEL_PRESET_CHUTES=chutes:moonshotai/Kimi-K2.6-TEE
# Hermes upstream pin fallback for early bootstrap. config/pins.json is the
# source of truth once the repo is present.
ARCLINK_HERMES_AGENT_REF=49c3c2e0d37c96dc593a807a5e81fdf4f0aa3d85
ARCLINK_HERMES_DOCS_SYNC_ENABLED=1
ARCLINK_HERMES_DOCS_REPO_URL=https://github.com/NousResearch/hermes-agent.git
# Docs pin fallback for early bootstrap. config/pins.json keeps docs aligned
# with the pinned runtime once the repo is present.
ARCLINK_HERMES_DOCS_REF=49c3c2e0d37c96dc593a807a5e81fdf4f0aa3d85
ARCLINK_HERMES_DOCS_SOURCE_SUBDIR=website/docs
ARCLINK_HERMES_DOCS_STATE_DIR=/home/arclink/arclink/arclink-priv/state/hermes-docs-src
ARCLINK_HERMES_DOCS_VAULT_DIR=/home/arclink/arclink/arclink-priv/vault/Agents_KB/hermes-agent-docs
ARCLINK_EXTRA_MCP_NAME=external-kb
ARCLINK_EXTRA_MCP_LABEL="External knowledge rail"
ARCLINK_EXTRA_MCP_URL=
ARCLINK_AGENT_DASHBOARD_BACKEND_PORT_BASE=19000
ARCLINK_AGENT_DASHBOARD_PROXY_PORT_BASE=29000
ARCLINK_AGENT_PORT_SLOT_SPAN=5000
ARCLINK_SSOT_NOTION_ROOT_PAGE_URL=
ARCLINK_SSOT_NOTION_ROOT_PAGE_ID=
ARCLINK_SSOT_NOTION_SPACE_URL=
ARCLINK_SSOT_NOTION_SPACE_ID=
ARCLINK_SSOT_NOTION_SPACE_KIND=
ARCLINK_SSOT_NOTION_API_VERSION=2026-03-11
ARCLINK_SSOT_NOTION_TOKEN=
# Leave blank to follow ENABLE_TAILSCALE_SERVE.
ARCLINK_AGENT_ENABLE_TAILSCALE_SERVE=
ENABLE_PRIVATE_GIT=1
ENABLE_QUARTO=1
SEED_SAMPLE_VAULT=1

QUARTO_PROJECT_DIR=/home/arclink/arclink/arclink-priv/quarto
QUARTO_OUTPUT_DIR=/home/arclink/arclink/arclink-priv/published
