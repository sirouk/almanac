# ArcLink SaaS Environment Variables
# Copy to .env and fill in values. Never commit secrets to version control.
#
# ARCLINK_* values take precedence over legacy ARCLINK_* aliases when non-empty.
# Blank ARCLINK_* values fall back to legacy settings.

# Product Identity
ARCLINK_PRODUCT_NAME=ArcLink
ARCLINK_BASE_DOMAIN=arclink.online
ARCLINK_PRIMARY_PROVIDER=chutes

# Chutes Model Provider
ARCLINK_CHUTES_BASE_URL=https://llm.chutes.ai/v1
ARCLINK_CHUTES_DEFAULT_MODEL=moonshotai/Kimi-K2.6-TEE
ARCLINK_MODEL_REASONING_DEFAULT=medium
# CHUTES_API_KEY=               # Required for live model catalog and key management

# Hosted API
# ARCLINK_CORS_ORIGIN=https://arclink.online   # Allowed CORS origin
# ARCLINK_COOKIE_DOMAIN=arclink.online          # Cookie domain attribute
ARCLINK_COOKIE_SECURE=1                          # Set 0 for HTTP-only dev
ARCLINK_LOG_LEVEL=INFO
ARCLINK_DEFAULT_PRICE_ID=price_arclink_starter

# Stripe
# STRIPE_SECRET_KEY=             # Required for live billing, portal links
# STRIPE_WEBHOOK_SECRET=         # Required for webhook signature verification

# Cloudflare DNS / Ingress
# CLOUDFLARE_API_TOKEN=          # Scoped token: Zone:DNS:Edit
# CLOUDFLARE_ZONE_ID=            # Target zone for arclink.online

# Docker Executor
# ARCLINK_EXECUTOR_LIVE=1        # Enable live Docker/provider execution (off by default)

# Telegram Bot
# TELEGRAM_BOT_TOKEN=            # Public onboarding bot; fake mode when absent

# Discord Bot
# DISCORD_BOT_TOKEN=             # Public onboarding bot; fake mode when absent
# DISCORD_APP_ID=                # Discord application ID for interaction verification

# Database
# ARCLINK_DB_PATH=               # SQLite path (default: arclink-priv/state/arclink-control.sqlite3)

# Legacy ArcLink (kept for backward compatibility)
# See config/arclink.env.example for the full legacy variable list.
# ARCLINK_NAME=arclink
# ARCLINK_ORG_NAME=
# ARCLINK_ORG_PROVIDER_SECRET=
